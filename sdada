-- CONTENT
local contentHolder = Instance.new("Frame")
contentHolder.Size = UDim2.new(1, -150, 1, -30)
contentHolder.Position = UDim2.new(0, 150, 0, 30)
contentHolder.BackgroundTransparency = 1
contentHolder.Parent = main

local tabs = {}

local function createTab(name)
	local tab = Instance.new("Frame")
	tab.Size = UDim2.new(1,0,1,0)
	tab.Visible = false
	tab.BackgroundTransparency = 1
	tab.Parent = contentHolder
	tabs[name] = tab
	return tab
end

local function switchTab(name)
	for tabName, frame in pairs(tabs) do
		if tabName == name then
			frame.Visible = true
			frame.Position = UDim2.new(0,50,0,0)
			TweenService:Create(frame, TweenInfo.new(0.25), {
				Position = UDim2.new(0,0,0,0)
			}):Play()
		else
			frame.Visible = false
		end
	end
end

local function createSidebarButton(name, y)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 35)
	btn.Position = UDim2.new(0, 5, 0, y)
	btn.Text = name
	btn.BackgroundColor3 = Color3.fromRGB(45,45,45)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = sidebar
	
	btn.MouseButton1Click:Connect(function()
		switchTab(name)
	end)
end

