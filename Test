local Camera = workspace.CurrentCamera

-- Hàm chờ an toàn, không gây lag
local function wait(seconds)
    local start = os.clock()
    while os.clock() - start < seconds do
        Services.RunService.Heartbeat:Wait()
    end
end

-- Kiểm tra nhân vật hợp lệ
local function isCharacterAlive(character)
    if not character then
        character = LocalPlayer.Character
    end
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

-- Lấy HumanoidRootPart an toàn
local function getRootPart(character)
    if not character then character = LocalPlayer.Character end
    if not character then return nil end
    return character:FindFirstChild("HumanoidRootPart")
end

-- Tính khoảng cách giữa 2 Vector3
local function distance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

