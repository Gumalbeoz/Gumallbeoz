-- Toggle tự động né tránh sát thương
local AutoDodgeToggle = FlyFarmTab:CreateToggle({
   Name = "Tự động né tránh (Invincibility Frame)",
   CurrentValue = false,
   Flag = "AutoDodge",
   Callback = function(Value)
       _G.AutoDodge = Value
       if _G.AutoDodge then
           spawn(function()
               while _G.AutoDodge do
                   pcall(function()
                       local player = game.Players.LocalPlayer
                       local character = player.Character
                       if character and character:FindFirstChild("Humanoid") then
                           -- Tạo i-frame bằng cách tăng tốc di chuyển cực nhanh trong thời gian ngắn
                           local humanoid = character.Humanoid
                           -- Vô hiệu hóa sát thương
                           humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                           humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                       end
                   end)
                   wait(0.1)
               end
           end)
       end
   end
})

-- Toggle chống rơi khi tắt bay
local AntiFallToggle = FlyFarmTab:CreateToggle({
   Name = "Chống rơi khi tắt farm",
   CurrentValue = true,
   Flag = "AntiFall",
   Callback = function(Value)
       _G.AntiFall = Value
       if _G.AntiFall then
           -- Tạo sự kiện khi tắt farm để hạ cánh an toàn
           local oldValue = _G.FlyFarmMode
           spawn(function()
               while true do
                   if oldValue == true and _G.FlyFarmMode == false then
                       -- Khi tắt farm, hạ cánh từ từ
                       pcall(function()
                           local player = game.Players.LocalPlayer
                           local character = player.Character
                           if character then
                               local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                               if humanoidRootPart then
                                   -- Hạ cánh an toàn
                                   local raycastParams = RaycastParams.new()
                                   raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                                   raycastParams.FilterDescendantsInstances = {character}
                                   
                                   local raycastResult = workspace:Raycast(
                                       humanoidRootPart.Position,
                                       Vector3.new(0, -500, 0),
                                       raycastParams
                                   )
                                   
                                   if raycastResult then
                                       humanoidRootPart.CFrame = CFrame.new(
                                           raycastResult.Position + Vector3.new(0, 3, 0)
                                       )
                                   end
                                   
                                   -- Xóa BodyVelocity và BodyGyro
                                   if humanoidRootPart:FindFirstChild("FlyVelocity") then
                                       humanoidRootPart.FlyVelocity:Destroy()
                                   end
                                   if humanoidRootPart:FindFirstChild("FlyGyro") then
                                       humanoidRootPart.FlyGyro:Destroy()
                                   end
                               end
                           end
                       end)
                   end
                   oldValue = _G.FlyFarmMode
                   wait(0.5)
               end
           end)
       end
   end
})

-- Nút dừng tất cả
local StopAllButton = FlyFarmTab:CreateButton({
