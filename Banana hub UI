-- Toggle bật/tắt Auto Farm kiểu bay
local FlyFarmToggle = FlyFarmTab:CreateToggle({
   Name = "Auto Farm Kiểu Bay",
   CurrentValue = false,
   Flag = "FlyFarmMode",
   Callback = function(Value)
       _G.FlyFarmMode = Value
       if _G.FlyFarmMode then
           spawn(function()
               -- Vòng lặp chính của farm kiểu bay
               while _G.FlyFarmMode do
                   pcall(function()
                       local player = game.Players.LocalPlayer
                       local character = player.Character or player.CharacterAdded:Wait()
                       local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
                       local humanoid = character:WaitForChild("Humanoid")
                       
                       -- Tìm quái gần nhất
                       local nearestEnemy = nil
                       local nearestDistance = math.huge
                       
                       for _, enemy in pairs(game.Workspace.Enemies:GetChildren()) do
                           if enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                               if enemy:FindFirstChild("HumanoidRootPart") then
                                   local distance = (humanoidRootPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                                   if distance <= _G.FarmRadius then
                                       if distance < nearestDistance then
                                           nearestDistance = distance
                                           nearestEnemy = enemy
                                       end
                                   end
                               end
                           end
                       end
                       
                       if nearestEnemy then
                           -- Bật bay cho nhân vật
                           if not humanoidRootPart:FindFirstChild("BodyVelocity") then
                               local bodyVelocity = Instance.new("BodyVelocity")
                               bodyVelocity.Name = "FlyVelocity"
                               bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
                               bodyVelocity.Parent = humanoidRootPart
                           end
                           
                           if not humanoidRootPart:FindFirstChild("BodyGyro") then
                               local bodyGyro = Instance.new("BodyGyro")
                               bodyGyro.Name = "FlyGyro"
                               bodyGyro.MaxTorque = Vector3.new(1, 1, 1) * math.huge
                               bodyGyro.CFrame = humanoidRootPart.CFrame
                               bodyGyro.Parent = humanoidRootPart
                           end
                           
                           -- Tính toán vị trí bay phía trên đầu quái
                           local flyHeight = _G.FlyHeightOffset or 15
                           local targetPosition = nearestEnemy.HumanoidRootPart.Position + Vector3.new(0, flyHeight, 0)
                           
                           -- Di chuyển đến vị trí phía trên đầu quái
                           humanoidRootPart.CFrame = CFrame.new(
                               targetPosition,
                               nearestEnemy.HumanoidRootPart.Position
                           )
                           
                           -- Cập nhật BodyVelocity để giữ vị trí
                           local flyVelocity = humanoidRootPart:FindFirstChild("FlyVelocity")
                           if flyVelocity then
                               flyVelocity.Velocity = Vector3.new(0, 0.1, 0) -- Giữ độ cao ổn định
                           end
                           
                           -- Cập nhật BodyGyro để nhìn xuống quái
                           local flyGyro = humanoidRootPart:FindFirstChild("FlyGyro")
                           if flyGyro then
                               flyGyro.CFrame = CFrame.new(
                                   humanoidRootPart.Position,
                                   nearestEnemy.HumanoidRootPart.Position
                               )
                           end
                           
                           -- Tự động trang bị vũ khí có tầm đánh xa nhất
                           local bestTool = nil
                           local bestRange = 0
                           local attackRangeMultiplier = _G.AttackRangeMultiplier or 3
                           
                           for _, tool in pairs(character:GetChildren()) do
                               if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                                   local toolRange = (tool.Handle.Position - humanoidRootPart.Position).Magnitude
                                   if toolRange > bestRange then
                                       bestRange = toolRange
                                       bestTool = tool
                                   end
                               end
                           end
                           
                           -- Trang bị vũ khí tốt nhất
                           if bestTool and character:FindFirstChildOfClass("Tool") ~= bestTool then
                               humanoid:EquipTool(bestTool)
                           end
                           
                           -- Tấn công với tốc độ đánh được cấu hình
                           local currentTool = character:FindFirstChildOfClass("Tool")
                           if currentTool then
                               local attackDelay = _G.AttackSpeed or 0.01
                               
                               -- Kích hoạt tấn công
                               currentTool:Activate()
                               
                               -- Gửi sự kiện tấn công qua Remote để tăng tầm đánh
                               local attackArgs = {
                                   [1] = nearestEnemy.HumanoidRootPart.Position,
                                   [2] = nearestEnemy
                               }
                               
                               -- Tăng tầm đánh bằng cách chỉnh sửa Hitbox
                               pcall(function()
                                   -- Mở rộng hitbox của vũ khí
                                   local handle = currentTool:FindFirstChild("Handle")
                                   if handle then
                                       handle.Size = Vector3.new(
                                           handle.Size.X * attackRangeMultiplier,
                                           handle.Size.Y * attackRangeMultiplier,
                                           handle.Size.Z * attackRangeMultiplier
                                       )
                                       handle.Transparency = 0.7
                                       handle.Massless = true
                                       handle.CanCollide = false
                                   end
                               end)
                               
                               -- Tấn công liên tục với tốc độ cao
                               for i = 1, 5 do
                                   pcall(function()
                                       game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(
                                           "Hit", "Melee", nearestEnemy
                                       )
                                   end)
                                   wait(attackDelay / 5)
                               end
                               
                               wait(attackDelay)
                           end
                       end
                   end)
                   wait(0.001) -- Tốc độ vòng lặp cực nhanh
               end
           end)
       end
   end
})

