-- Toggle Bypass Detection
local BypassDetectionToggle = FastAttackTab:CreateToggle({
   Name = "Bypass Anti-Cheat Detection",
   CurrentValue = true,
   Flag = "BypassDetection",
   Callback = function(Value)
       _G.BypassDetection = Value
       if _G.BypassDetection then
           spawn(function()
               while _G.BypassDetection do
                   pcall(function()
                       -- Vô hiệu hóa các module chống cheat
                       local antiCheatModules = {
                           "Kick",
                           "Ban", 
                           "Detect",
                           "AntiCheat",
                           "CheatDetection",
                           "AntiExploit"
                       }
                       
                       -- Tìm và vô hiệu hóa các module chống cheat
                       for _, moduleName in pairs(antiCheatModules) do
                           pcall(function()
                               -- Quét qua các service
                               for _, service in pairs(game:GetChildren()) do
                                   if service:FindFirstChild(moduleName) then
                                       service[moduleName]:Destroy()
                                   end
                               end
                               
                               -- Quét qua replicated storage
                               if game:GetService("ReplicatedStorage"):FindFirstChild(moduleName) then
                                   game:GetService("ReplicatedStorage")[moduleName]:Destroy()
                               end
                               
                               -- Quét qua server storage
                               if game:GetService("ServerStorage"):FindFirstChild(moduleName) then
                                   game:GetService("ServerStorage")[moduleName]:Destroy()
                               end
                           end)
                       end
                       
                       -- Vô hiệu hóa script kick
                       local player = game.Players.LocalPlayer
                       local oldKick = player.Kick
                       player.Kick = function() end
                       
                       -- Bảo vệ khỏi bị kick bởi remote events
                       local remoteConnections = {}
                       for _, remote in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
                           if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                               if remote.Name:lower():find("kick") or remote.Name:lower():find("ban") then
                                   remote:Destroy()
                               end
                           end
                       end
                   end)
                   wait(1)
               end
           end)
       end
   end
})

